<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- FWPlayer Remote does not track users, runs no advertising, and
	     contacts no tracking domains. It only talks to the FWPlayer instance
	     the user picks on their own local network. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- No data is collected from the device. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason API declarations. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- @AppStorage / UserDefaults remembers the last paired player —
			     readable only by the app. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
